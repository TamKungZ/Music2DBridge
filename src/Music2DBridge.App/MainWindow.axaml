<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Music2DBridge.App.MainWindow"
        Title="Music2DBridge"
        Width="1512"
        Height="744"
        MinWidth="760"
        MinHeight="500">
  <Grid RowDefinitions="Auto,Auto,*" Margin="16">
    <TextBlock Text="Music2DBridge"
               FontSize="24"
               FontWeight="Bold" />

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,12,0,12">
      <Button Content="Start" Command="{Binding StartCommand}" IsEnabled="{Binding IsStopped}" Width="120" />
      <Button Content="Stop" Command="{Binding StopCommand}" IsEnabled="{Binding IsRunning}" Width="120" />
      <TextBlock VerticalAlignment="Center" Text="Note mode:" Margin="8,0,0,0" />
      <ComboBox Width="140"
                ItemsSource="{Binding AvailableNoteModes}"
                SelectedItem="{Binding SelectedNoteMode}"
                IsEnabled="{Binding IsStopped}" />
      <TextBlock VerticalAlignment="Center" Text="Gain:" Margin="8,0,0,0" />
      <Slider Width="120"
              Minimum="0.1"
              Maximum="8.0"
              Value="{Binding InputGain}"
              IsEnabled="{Binding IsStopped}" />
      <TextBlock VerticalAlignment="Center" Text="{Binding InputGainText}" />
      <TextBlock VerticalAlignment="Center" Text="Gate:" Margin="8,0,0,0" />
      <Slider Width="120"
              Minimum="0.0"
              Maximum="0.08"
              Value="{Binding NoiseGate}"
              IsEnabled="{Binding IsStopped}" />
      <TextBlock VerticalAlignment="Center" Text="{Binding NoiseGateText}" />
      <TextBlock VerticalAlignment="Center" Text="Input:" Margin="8,0,0,0" />
      <ComboBox Width="220"
                ItemsSource="{Binding AvailableInputDevices}"
                DisplayMemberBinding="{Binding DisplayName}"
                SelectedValueBinding="{Binding Id}"
                SelectedValue="{Binding SelectedInputDeviceId}"
                IsEnabled="{Binding IsStopped}" />
      <Button Content="+" Width="36"
              Command="{Binding EnableFixedKeyCommand}"
              IsVisible="{Binding ShowFixedKeyAddButton}" />
      <TextBlock VerticalAlignment="Center"
                 Text="(fixed key)"
                 Margin="8,0,0,0"
                 IsVisible="{Binding ShowFixedKeyLabel}" />
      <ComboBox Width="110"
                ItemsSource="{Binding AvailableFixedKeys}"
                SelectedItem="{Binding FixedKeySpec}"
                IsVisible="{Binding ShowFixedKeyEditor}"
                IsEnabled="{Binding IsStopped}" />
      <Button Content="-" Width="36"
              Command="{Binding DisableFixedKeyCommand}"
              IsVisible="{Binding ShowFixedKeyEditor}"
              IsEnabled="{Binding IsStopped}" />
      <TextBlock VerticalAlignment="Center" Text="{Binding StatusText}" />
    </StackPanel>

    <Grid Grid.Row="2" ColumnDefinitions="2*,3*" ColumnSpacing="12">
      <Border BorderBrush="#3A3A3A" BorderThickness="1" Padding="12" CornerRadius="8">
        <StackPanel Spacing="6">
          <TextBlock Text="CLI Usage" FontWeight="Bold" />
          <TextBlock TextWrapping="Wrap" Text="Run same executable in terminal mode:" />
          <TextBlock Text="Music2DBridge --cli --note-mode=class" />
          <TextBlock Text="Music2DBridge --cli --note-mode=per-note" />
          <TextBlock Margin="0,8,0,0" Text="Mode class: ParamInstNoteClass = 0..11" />
          <TextBlock Text="Mode per-note: ParamInstNote[C/Cs/D/.../B] = 0..1" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" BorderBrush="#3A3A3A" BorderThickness="1" Padding="12" CornerRadius="8">
        <StackPanel Spacing="10">
          <Border BorderBrush="#4A4A4A" BorderThickness="1" Padding="10" CornerRadius="6">
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="4">
              <TextBlock Text="Note" FontWeight="Bold" />
              <TextBlock Grid.Column="1" Text="{Binding CurrentNote}" FontSize="16" FontWeight="Bold" />
              <TextBlock Grid.Column="2" Text="Chord" FontWeight="Bold" />
              <TextBlock Grid.Column="3" Text="{Binding CurrentChord}" FontSize="16" FontWeight="Bold" />
              <TextBlock Grid.Column="4" Text="Key" FontWeight="Bold" />
              <TextBlock Grid.Column="5" Text="{Binding CurrentKey}" FontSize="16" FontWeight="Bold" />

              <TextBlock Grid.Row="1" Text="Pitch" FontWeight="Bold" />
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentPitch}" />
              <TextBlock Grid.Row="1" Grid.Column="2" Text="Energy" FontWeight="Bold" />
              <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding CurrentEnergy}" />
            </Grid>
          </Border>
          <TextBlock Text="Runtime Log" FontWeight="Bold" Margin="0,0,0,8" />
          <TextBox Text="{Binding LogText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" Height="360" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
